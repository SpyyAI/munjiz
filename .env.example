DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-in-production-please-use-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx,0.0.0.0

DATABASE_URL=postgres://munjiz:munjiz_secure_2026@db:5432/munjiz
REDIS_URL=redis://redis:6379/0

# OpenRouter (FREE Qwen models). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_DEFAULT=qwen/qwen-2.5-72b-instruct:free
LLM_MODEL_ORCHESTRATOR=qwen/qwen-2.5-72b-instruct:free

# Alternative providers (uncomment to switch):
# Groq (free tier): LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL_DEFAULT=qwen-qwq-32b
# Ollama (local):  LLM_BASE_URL=http://ollama:11434/v1            LLM_MODEL_DEFAULT=qwen3:32b

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
